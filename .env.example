# ══════════════════════════════════════════════════════════════
#  CricketLiveNews / SyndicateHub — Environment Variables
#  Copy to .env.local for local dev, add to Vercel dashboard for prod
#  NEVER commit .env.local to git
# ══════════════════════════════════════════════════════════════

# ── SITE IDENTITY ──────────────────────────────────────────────
# NICHE: loads the niche config file (config/niches/<NICHE>.config.js)
NICHE=cricket

# SITE_NAME: used in EVERY Supabase query to isolate this site's data
# Must be unique per site in your 10-site network
# Examples: cricket, forex, crypto, sharemarket, realestate
SITE_NAME=cricket

# Language: english | hindi (future feature)
LANGUAGE_MODE=english

# ── AI CONTENT ──────────────────────────────────────────────────
GROQ_API_KEY=

# ── IMAGES ──────────────────────────────────────────────────────
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── DATABASE (Supabase) ──────────────────────────────────────────
# All 10 sites share ONE Supabase project — site_name column separates data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── SECURITY ─────────────────────────────────────────────────────
# Used to authenticate cron endpoint — generate a long random string
# e.g.: openssl rand -hex 32
CRON_SECRET=
SITE_API_PASSWORD=

# ── SITE URL ─────────────────────────────────────────────────────
# Used for: canonical URLs, OG tags, sitemap, IndexNow, robots.txt
NEXT_PUBLIC_SITE_URL=https://cricketlivenews.in

# ── ANALYTICS & ADS (optional) ───────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ── LIMITS ───────────────────────────────────────────────────────
# Posts to keep per site before auto-deleting oldest
MAX_POSTS_PER_SITE=30
# Posts to generate per cron run (default: 3)
POSTS_PER_RUN=3

# ── OPTIONAL NEWS APIS ────────────────────────────────────────────
NEWS_API_KEY=
CRICAPI_KEY=
THESPORTSDB_KEY=
MEDIASTACK_KEY=
CURRENTS_API_KEY=
GUARDIAN_API_KEY=

# ── SEO / INDEXING ────────────────────────────────────────────────
INDEX_NOW_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
